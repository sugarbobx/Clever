# ── CLEVER local MVP env (no Docker / Postgres / Redis required) ──
# The app is a single full-stack Next.js project. Copy the values below into
# apps/web-client/.env (loaded by both Next.js and the Prisma CLI).

# Database — local SQLite file (path is resolved against prisma/).
# Swap to a Postgres URL for the server-backed phase.
DATABASE_URL="file:./dev.db"

NODE_ENV="development"

# Auth — generate long random strings for real use
JWT_SECRET="dev_access_secret_change_me_please_64_chars_minimum_aaaaaaaaaaaa"
JWT_REFRESH_SECRET="dev_refresh_secret_change_me_please_different_64_chars_bbbbbbbb"

# Local file uploads (resolved against the app root, apps/web-client)
UPLOAD_DIR="./data/uploads"
MAX_FILE_SIZE_MB=10

# Optional: point the browser client at an external API instead of same-origin /api
# (apps/web-client/.env.local)
# NEXT_PUBLIC_API_URL=/api

# ── Deferred to server-backed phase (NOT needed for local MVP) ──
# REDIS_URL=
# ANTHROPIC_API_KEY=          # real Claude OCR
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_APP_SECRET=
# QBO_CLIENT_ID=
# QBO_CLIENT_SECRET=
# QBO_REDIRECT_URI=
# QBO_ENVIRONMENT=sandbox
